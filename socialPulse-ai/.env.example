# ══════════════════════════════════════════════════════════════════════════════
#  SocialPulse AI — Environment Variables
#  Copy this file to .env and fill in the values before running docker-compose.
# ══════════════════════════════════════════════════════════════════════════════

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development                          # development | production
APP_VERSION=0.1.0
LOG_LEVEL=info

# ── Frontend (Next.js) ─────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=SocialPulse AI
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Backend (FastAPI) ──────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_use_openssl_rand_hex_32   # openssl rand -hex 32
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ── MongoDB ────────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb+srv://vaibhavdamor2512_db_user:<db_password>@cluster0.sltwebz.mongodb.net/?appName=Cluster0
MONGODB_DB_NAME=socialpulse
MONGODB_MAX_CONNECTIONS=10
MONGODB_MIN_CONNECTIONS=1

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── IBM Cloud ──────────────────────────────────────────────────────────────────
IBM_CLOUD_API_KEY=YOUR_IBM_CLOUD_API_KEY
IBM_CLOUD_REGION=us-south                    # e.g. us-south, eu-gb

# ── IBM Granite (watsonx.ai) ───────────────────────────────────────────────────
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_PROJECT_ID=YOUR_WATSONX_PROJECT_ID
WATSONX_MODEL_ID=ibm/granite-13b-instruct-v2
WATSONX_MAX_NEW_TOKENS=1024
WATSONX_TEMPERATURE=0.7
WATSONX_TOP_P=0.9

# ── IBM Langflow ───────────────────────────────────────────────────────────────
LANGFLOW_BASE_URL=http://localhost:7860
LANGFLOW_FLOW_ID=YOUR_LANGFLOW_FLOW_ID
LANGFLOW_API_KEY=YOUR_LANGFLOW_API_KEY

# ── IBM Watson NLP ─────────────────────────────────────────────────────────────
WATSON_NLP_URL=https://api.us-south.natural-language-understanding.watson.cloud.ibm.com
WATSON_NLP_API_KEY=YOUR_WATSON_NLP_API_KEY
WATSON_NLP_VERSION=2022-04-07

# ── OAuth (optional — stub for hackathon) ──────────────────────────────────────
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GITHUB_CLIENT_ID=YOUR_GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=YOUR_GITHUB_CLIENT_SECRET

# ── Report storage ─────────────────────────────────────────────────────────────
REPORTS_DIR=/app/reports                     # directory inside the backend container
